@startuml
scale 1.35
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam maxMessageSize 90
title Detail 2: Load Owner + Status Guard

participant "OwnerUcActivate" as U
participant "EmployeesRepository" as R
participant "Owner Aggregate" as O

U -> R : FindById(customerId)
alt not found
  R --> U : null (404)
else found
  R --> U : Owner
  U -> O : EnsureStatus(Provisioned)
  alt wrong status
    O --> U : Failure (409)
  else ok
    O --> U : OK
  end
end
@enduml
